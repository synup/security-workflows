#!/usr/bin/env bash
#
# Synup org pre-commit hook
# ------------------------------------------------------------------
# 1. Runs scan_malware.py against the *staged* content of this commit
#    and blocks the commit on any high/critical finding.
# 2. Chains to any repo-local hooks (.git/hooks/pre-commit, .husky/pre-commit)
#    so existing project hooks keep working under a global core.hooksPath.
#
# Installed org-wide via install.sh (sets git config --global core.hooksPath).
#
# Escape hatches (use sparingly, you own the consequences):
#   git commit --no-verify            # skip ALL hooks
#   SYNUP_SKIP_MALWARE_SCAN=1 git ... # skip only the malware scan
#   SYNUP_HOOK_STRICT=1               # treat scanner infra failures as blocking
# ------------------------------------------------------------------
set -uo pipefail

HOOK_DIR="$(cd "$(dirname "$0")" && pwd)"
SCANNER="$HOOK_DIR/../scripts/scan_malware.py"
REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"

RED='\033[0;31m'; YEL='\033[1;33m'; GRN='\033[0;32m'; RST='\033[0m'
log() { printf "%b\n" "$*" >&2; }

# ---------- infra failure handling ----------
# Default: warn-and-allow so a missing dependency never bricks everyone's
# commits. Set SYNUP_HOOK_STRICT=1 to make these blocking instead.
infra_fail() {
  if [ "${SYNUP_HOOK_STRICT:-}" = "1" ]; then
    log "${RED}[synup] $1 (strict mode → blocking)${RST}"
    exit 1
  fi
  log "${YEL}[synup] $1 — skipping scan (set SYNUP_HOOK_STRICT=1 to block)${RST}"
  return 1
}

# ---------- malware / secret scan of staged content ----------
run_scan() {
  [ "${SYNUP_SKIP_MALWARE_SCAN:-}" = "1" ] && { log "${YEL}[synup] malware scan skipped (SYNUP_SKIP_MALWARE_SCAN=1)${RST}"; return 0; }
  command -v python3 >/dev/null 2>&1 || { infra_fail "python3 not found"; return $?; }
  [ -f "$SCANNER" ] || { infra_fail "scanner missing at $SCANNER (run install.sh to update)"; return $?; }

  # Nothing staged (added/copied/modified) → nothing to scan.
  [ -n "$(git diff --cached --name-only --diff-filter=ACM)" ] || return 0

  local tmp; tmp="$(mktemp -d "${TMPDIR:-/tmp}/synup-scan.XXXXXX")" || { infra_fail "mktemp failed"; return $?; }
  trap 'rm -rf "$tmp"' RETURN

  # Materialize the *staged* blob of each file (not the working tree) so we
  # scan exactly what's being committed, even with partial `git add -p`.
  git diff --cached --name-only --diff-filter=ACM -z | while IFS= read -r -d '' f; do
    mkdir -p "$tmp/$(dirname "$f")"
    git show ":$f" > "$tmp/$f" 2>/dev/null || true
  done

  # Dir mode respects SKIP_DIRS/SKIP_EXT and exits 1 on high/critical.
  if python3 "$SCANNER" "$tmp" --min-severity high; then
    log "${GRN}[synup] malware scan clean ✓${RST}"
    return 0
  fi

  log ""
  log "${RED}[synup] ✗ COMMIT BLOCKED — malware/secret scan found high/critical issues in your staged changes.${RST}"
  log "Review the findings above and fix them. If you are certain this is a false positive:"
  log "    ${YEL}SYNUP_SKIP_MALWARE_SCAN=1 git commit ...${RST}   (and please report the false positive)"
  return 1
}

# ---------- chain to a repo-local hook ----------
# Under a global core.hooksPath, git no longer runs .git/hooks/* itself, so we
# invoke them here to preserve per-project behavior.
run_repo_hook() {
  local h="$1"
  [ -f "$h" ] && [ -x "$h" ] || return 0
  # Don't recurse into ourselves.
  [ "$(cd "$(dirname "$h")" && pwd)/$(basename "$h")" = "$HOOK_DIR/pre-commit" ] && return 0
  log "${YEL}[synup] running repo hook: ${h#"$REPO_ROOT"/}${RST}"
  "$h"
}

run_scan || exit 1
run_repo_hook "$REPO_ROOT/.git/hooks/pre-commit" || exit $?
run_repo_hook "$REPO_ROOT/.husky/pre-commit"     || exit $?
exit 0
